  "keyFeatures": [
    "Upload images and videos (signed and unsigned) with progress tracking and cancellation",
    "Generate optimized Cloudinary CDN URLs with chained transformations",
    "Image and video transformations: crop, resize, gravity, effects, overlays, and more",
    "CLDUIImageView for asynchronous image loading with responsive/adaptive sizing",
    "CLDVideoPlayer (AVPlayer subclass) with analytics and streaming profile support",
    "Upload Widget with built-in crop and preprocessing UI",
    "Image and video preprocessing pipeline (resize, format, quality, custom steps)",
    "Management API for renaming, deleting, tagging, and explicitly managing assets",
    "Supports CocoaPods, Carthage, Swift Package Manager, and manual integration",
    "Native URLCache support with configurable disk and memory limits"
  ],
